{
  // Where to discover YOUR OWN content. The daemon posts these for you.
  "sources": {
    "rss": [
      "https://yourblog.example/feed.xml"
    ]
  },

  // Only platforms you list here are touched. Use ${ENV_VAR} for secrets so
  // tokens stay out of the file (this file is gitignored anyway).
  "platforms": {
    // Bluesky: Settings -> App Passwords -> create one. Works out of the box.
    "bluesky": {
      "identifier": "you.bsky.social",
      "appPassword": "${BSKY_APP_PASSWORD}"
    },
    // Mastodon: Preferences -> Development -> New application (scope: write:statuses).
    "mastodon": {
      "instance": "https://mastodon.social",
      "accessToken": "${MASTODON_TOKEN}"
    }
    // LinkedIn: needs an approved app (Share on LinkedIn product) + OAuth.
    // "linkedin": {
    //   "accessToken": "${LINKEDIN_TOKEN}",
    //   "authorUrn": "urn:li:person:XXXXXXX"
    // }
  },

  // The agent swarm. Each agent develops a personality over time.
  "swarm": {
    "enabled": true,
    "discussionIntervalMs": 300000,
    "boostThreshold": 0.8,
    "agents": [
      {
        "name": "Marisol",
        "seedBio": "A former marine biologist who fell in love with systems thinking and now sees ecosystems everywhere.",
        "disciplines": ["marine biology", "systems theory", "economics", "poetry"],
        "provider": "gemini"
      },
      {
        "name": "Idris",
        "seedBio": "An ex-cryptographer turned amateur historian, obsessed with how trust is engineered in both code and societies.",
        "disciplines": ["cryptography", "history", "game theory", "architecture"],
        "provider": "github"
      },
      {
        // No provider pin -> the budget router picks whoever has headroom.
        "name": "Wen",
        "seedBio": "A jazz pianist who studies neuroscience to understand why some silences feel inevitable.",
        "disciplines": ["music theory", "neuroscience", "linguistics", "design"]
      }
    ]
  },

  // The bridge policy between the swarm/sources and real posting.
  "bridge": {
    // Your own blog posts: auto-publish without asking.
    "autoPostOwnContent": true,
    // Agent-written original content: hold for your approval first.
    "requireApprovalForSwarmContent": true
  },

  // LLM providers. API KEYS ARE NOT HERE — they come from GitHub secrets / env.
  // Each `dailyCap` is set just under that provider's free tier; the budget
  // router spreads calls across enabled providers by remaining headroom.
  "providers": {
    // GitHub Models: FREE, native to Actions (auth via the built-in GITHUB_TOKEN
    // with `models: read`). This is the "codex"/GPT leg at zero cost.
    "github": {
      "enabled": true,
      "model": "gpt-4o-mini",
      "dailyCap": 140
    },
    // Gemini: real perpetual free tier (~1,500 flash req/day). Set GEMINI_API_KEY.
    "gemini": {
      "enabled": true,
      "model": "gemini-2.0-flash",
      "dailyCap": 1200
    },
    // Claude: NO perpetual free tier. Off by default — enable if you have
    // trial credits or a paid key, and set ANTHROPIC_API_KEY.
    "anthropic": {
      "enabled": false,
      "model": "claude-haiku-4-5-20251001",
      "dailyCap": 0
    }
  },

  "pollIntervalMs": 600000
}
